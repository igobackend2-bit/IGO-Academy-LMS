{
  "name": "igo-server",
  "version": "1.0.0",
  "description": "IGo Academy Platform — Node.js API Server",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:init": "node src/scripts/db-init.js",
    "migrate": "knex --knexfile src/config/knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile src/config/knexfile.js migrate:rollback",
    "seed": "knex --knexfile src/config/knexfile.js seed:run",
    "test": "jest"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.49.4",
    "@upstash/redis": "1.34.3",
    "axios": "1.7.9",
    "bcryptjs": "2.4.3",
    "cookie": "0.7.2",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "csv-parser": "3.0.0",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "express-validator": "7.2.1",
    "fast-csv": "4.3.6",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "8.0.0",
    "joi": "17.13.3",
    "jsonwebtoken": "9.0.2",
    "knex": "3.1.0",
    "morgan": "1.10.0",
    "multer": "1.4.4",
    "nanoid": "3.3.7",
    "node-cron": "3.0.3",
    "nodemailer": "6.9.16",
    "pg": "8.13.3",
    "puppeteer": "^23.11.1",
    "qrcode": "1.5.4",
    "razorpay": "^2.9.6",
    "uuid": "9.0.1",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.1.9",
    "supertest": "7.1.0"
  }
}
