{
  "name": "igo-platform",
  "version": "1.0.0",
  "description": "IGo Academy Learning Platform — 100% Custom LMS",
  "private": true,
  "scripts": {
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "dev": "concurrently --kill-others-on-fail -n SERVER,CLIENT -c green,cyan \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "build:client": "npm --prefix client run build",
    "seed": "npm --prefix server run seed",
    "migrate": "npm --prefix server run migrate",
    "migrate:rollback": "npm --prefix server run migrate:rollback"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
