# Dependencies
node_modules/
.pnp
.pnp.js

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local
.env.production
.env.staging

# Build outputs
dist/
build/
.next/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# AWS
.aws/

# User-uploaded files — never commit
server/uploads/
client/public/hero-bg.mp4

# Expo / React Native
.expo/
mobile/.expo/
mobile/dist/
mobile/web-build/

# Certificates (local dev only — never commit real certs)
*.pem
*.key
*.crt
# Exception: Supabase's PUBLIC root CA. Contains no private key — it is the
# trust anchor published by Supabase so clients can verify the pooler's
# certificate. Must be committed or production cannot reach the database.
!server/src/config/supabase-ca-2021.crt
