# ============================================================
# IGo Academy Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── Supabase (PostgreSQL Database) ──────────────────────────
# Get these from your Supabase project: Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── PostgreSQL direct (Supabase) ─────────────────────────────
# NOTE: use the Session Pooler host from Supabase (Settings -> Database -> Connection Pooling)
# if the direct db.<ref>.supabase.co host is not reachable from your network (common on IPv4-only networks).
DB_HOST=your-pooler-or-direct-host
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your_db_password
DB_SSL=true

# ── Redis (local dev / AWS ElastiCache prod) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=generate_a_long_random_string_here
JWT_EXPIRES_IN=7d
SESSION_INACTIVITY_MINUTES=30

# ── Supabase Storage (replaces AWS S3) ───────────────────────
SUPABASE_STORAGE_BUCKET_VIDEOS=igo-videos
SUPABASE_STORAGE_BUCKET_CERTS=igo-certificates
SUPABASE_STORAGE_BUCKET_UPLOADS=igo-uploads
SIGNED_URL_EXPIRY_SECONDS=7200

# ── AWS SES (Email) ──────────────────────────────────────────
SES_FROM_EMAIL=noreply@igoacademy.in
SES_FROM_NAME=IGo Academy
# Alternatively use SMTP:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_app_password

# ── MSG91 (SMS / OTP — India) ────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=IGOAKD
MSG91_OTP_TEMPLATE_ID=your_template_id
OTP_EXPIRY_MINUTES=10

# ── Firebase Cloud Messaging ─────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ── Certificate ──────────────────────────────────────────────
CERT_VERIFICATION_BASE_URL=https://igoacademy.in/verify

# ── Razorpay (Payment Gateway) ──────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_secret_here

# ── Cron ─────────────────────────────────────────────────────
EXPIRY_CRON_SCHEDULE=30 18 * * *
